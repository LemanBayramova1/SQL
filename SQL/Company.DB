CREATE DATABASE CompanyDB
CREATE Table Employees (
ID INT PRIMARY KEY IDENTITY(1,1),
FULLNAME NVARCHAR(50),
SALARY DECIMAL
)

CREATE TABLE Departments(
ID INT PRIMARY KEY IDENTITY(1,1),
DepartmentName	NVARCHAR(50)
)

ALTER TABLE Employees
Add Departmentid  INT




